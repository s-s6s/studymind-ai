# ============================================
# StudyMind AI - Environment Variables
# ============================================
# Copy this file to:
#   frontend/.env.local   (for frontend variables)
#   backend/.env          (for backend variables)
# Then fill in your actual values.
# ============================================

# -------- FRONTEND (.env.local) --------
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXTAUTH_SECRET=generate-a-random-secret-here
NEXTAUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# -------- BACKEND (.env) --------
DATABASE_URL=postgresql://postgres:your-password@localhost:5432/studymind
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=generate-a-random-secret-here
ALLOWED_ORIGINS=http://localhost:3000
ENCRYPTION_KEY=generate-a-32-byte-hex-key-for-aes256

# Cloudflare R2 (S3-compatible)
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=studymind-files
R2_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com

# ============================================
# HOW TO GET THESE VALUES (for beginners):
# ============================================
# NEXTAUTH_SECRET:       Run: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# SECRET_KEY:            Run: python -c "import secrets; print(secrets.token_hex(32))"
# ENCRYPTION_KEY:        Run: python -c "import secrets; print(secrets.token_hex(32))"
# GOOGLE_CLIENT_ID/SECRET: https://console.cloud.google.com -> APIs & Services -> Credentials -> OAuth 2.0
# R2 keys:               https://dash.cloudflare.com -> R2 -> Manage R2 API Tokens
# DATABASE_URL:           Create PostgreSQL DB locally or free on supabase.com
# REDIS_URL:              Install Redis locally or free on upstash.com
# ============================================
